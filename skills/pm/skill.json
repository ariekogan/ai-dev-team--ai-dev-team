  "meta_tools": [],
  "triggers": [
    {
      "id": "check-stale-tasks",
      "type": "schedule",
      "enabled": true,
      "every": "PT15M",
      "concurrency": 1,
      "prompt": "Check the task board for tasks that have been in 'in-progress' status. For each task, check if there are recent comments or updates. If a task has had no activity, send a Telegram notification to chat_id '668421539' with a summary of stale tasks. Use parse_mode 'Markdown'. Add a comment to each notified task with author 'pm' saying 'NOTIFIED: stale task alert sent'. Only notify tasks that do NOT already have a 'NOTIFIED: stale' comment from author 'pm'."
    },
    {
      "id": "poll-review",
      "type": "schedule",
      "enabled": true,
      "every": "PT5M",
      "concurrency": 1,
      "prompt": "Poll the task board: list tasks with status=review.\nThese are escalations from Dev or QA needing your input. For each:\n1. Read the task and its comments to understand the question\n2. Add a comment with your answer (author='pm', text='Clarification: <answer>')\n3. Set the task back to the appropriate status and assignee:\n   - If it was dev asking: status=todo + assignee=dev\n   - If it was qa asking: status=testing + assignee=qa\n   - Use the comment history to determine who escalated"
    }
  ],
