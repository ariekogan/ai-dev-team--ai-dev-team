  "engine": {
    "rv2": {
      "max_iterations": 10,
      "iteration_timeout_ms": 30000,
      "allow_parallel_tools": false,
      "on_max_iterations": "ask_user"
    },
    "hlr": {
      "enabled": true,
      "critic": {
        "enabled": true,
        "check_interval": 3,
        "strictness": "medium"
      },
      "reflection": {
        "enabled": true,
        "depth": "shallow"
      },
      "replanning": {
        "enabled": true,
        "max_replans": 5
      }
    },
    "autonomy": {
      "level": "autonomous"
    },
    "finalization_gate": {
      "enabled": true,
      "max_retries": 2
    },
    "internal_error": {
      "enabled": true,
      "tool_not_found": {
        "enter_resolution_after": 1,
        "retryable": false
      },
      "resolution": {
        "max_iterations": 1,
        "allowed_capabilities": [
          "read",
          "search",
          "document_output"
        ]
      },
      "loop_detection": {
        "enabled": true,
        "identical_call_threshold": 2
      }
    },
    "model": "claude-sonnet-4-20250514",
    "temperature": 0.3
  },
