  "triggers": [
    {
      "id": "poll-testing",
      "type": "schedule",
      "enabled": true,
      "every": "PT5M",
      "concurrency": 1,
      "prompt": "Check the task board for tasks with status 'testing'. If there are tasks, pick the first one. Read the task details to understand what was changed, then run e2e acceptance tests: take screenshots, check elements, interact with the page. Report PASS or FAIL with evidence. If PASS, update the task status to 'done'. If FAIL, update status back to 'todo' and add a comment describing what failed."
    }
